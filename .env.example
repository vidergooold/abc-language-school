# === BACKEND (Railway) ===

# Database — Railway автоматически заполняет эту переменную
# Пример Railway URL (custom CA не нужен, используйте стандартный SSL):
DATABASE_URL=postgresql://username:password@roundhouse.proxy.rlwy.net:5432/dbname?sslmode=require

# JWT
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Application base URL (used by scheduler for internal HTTP calls)
APP_BASE_URL=https://your-backend.railway.app

# Email (if used)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Frontend URL (для CORS/уведомлений)
FRONTEND_URL=https://abc-school-frontend.vercel.app

# Admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Migration endpoint key
MIGRATION_KEY=your-migration-key-here


# === FRONTEND (Vercel) ===
# Указать в настройках Vercel: Settings → Environment Variables
VITE_API_URL=https://your-backend.railway.app
