# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/abc_school

# JWT
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — comma-separated list of allowed frontend origins
# Local dev (Vite): http://localhost:5173
# Docker (nginx):   http://localhost:3000
CORS_ORIGINS=http://localhost:5173

# Internal API URL used by the scheduler (should match where the app is listening)
# Local dev: http://127.0.0.1:8000
# Docker:    http://backend:8000
INTERNAL_API_URL=http://127.0.0.1:8000

# Email (if used)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Migration
MIGRATION_KEY=your-migration-key-here
